{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/about",          "destination": "/about.html" },
    { "source": "/contact",        "destination": "/contact.html" },
    { "source": "/sourcing",       "destination": "/sourcing.html" },
    { "source": "/export-import",  "destination": "/export-import.html" },
    { "source": "/products/coffee",        "destination": "/products/coffee.html" },
    { "source": "/products/fruits",        "destination": "/products/fruits.html" },
    { "source": "/products/grains",        "destination": "/products/grains.html" },
    { "source": "/products/other-produce", "destination": "/products/other-produce.html" }
  ]
}
